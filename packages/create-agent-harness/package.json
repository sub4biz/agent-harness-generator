{
  "name": "mintagent",
  "version": "0.1.0",
  "description": "Paste any GitHub repo → get a custom AI agent harness. Browser Studio + npx CLI. Runs on Claude Code, Codex, pi.dev, Hermes, OpenClaw, RVM.",
  "homepage": "https://github.com/ruvnet/agent-harness-generator",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruvnet/agent-harness-generator.git",
    "directory": "packages/create-agent-harness"
  },
  "license": "MIT",
  "author": "rUv <ruv@ruv.net>",
  "type": "module",
  "bin": {
    "mintagent": "./dist/bin.js",
    "harness": "./dist/harness-bin.js"
  },
  "files": [
    "dist/**",
    "templates/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit",
    "gen:templates": "node scripts/gen-templates.mjs"
  },
  "keywords": [
    "mintagent",
    "agent-harness",
    "agent-harness-generator",
    "scaffold",
    "repo-to-agent",
    "mcp-server",
    "claude-code",
    "codex",
    "pi-dev",
    "hermes-agent",
    "openclaw",
    "rvm",
    "multi-agent",
    "agentic-ai",
    "autonomous-agents"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ruflo/kernel": "0.1.0",
    "kolorist": "^1.8.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "optionalDependencies": {
    "@ruvector/ruvllm": "^2.5.6"
  }
}
